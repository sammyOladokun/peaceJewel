{
  "name": "peace-jewel",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace @peacejewel/web",
    "dev:api": "npm run start:dev --workspace @peacejewel/api",
    "db:up": "docker compose up -d postgres redis mailhog",
    "db:down": "docker compose down",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
